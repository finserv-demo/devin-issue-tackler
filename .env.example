# === Required (for local scripts like setup_playbooks.py) ===
# Devin API key (apk_* service API key — v1 API).
# We use apk_* keys because cog_* keys return 403 on individual session
# endpoints (GET/POST/DELETE /sessions/{id}) in the v3 API.
DEVIN_API_KEY=apk_your_key_here

# Devin organization ID
DEVIN_ORG_ID=org-your-org-id-here

# GitHub token (PAT or App token with repo scope — used by setup scripts)
GITHUB_TOKEN=ghp_your_token_here

# === GitHub Actions Secrets ===
# These must be set as repository secrets in GitHub Settings > Secrets:
#   DEVIN_API_KEY    — same as above
#   DEVIN_ORG_ID     — same as above
#   GITHUB_TOKEN     — provided automatically by GitHub Actions

# === GitHub Actions Variables ===
# These should be set as repository variables in GitHub Settings > Variables:
#   TRIAGE_PLAYBOOK_ID    — from scripts/setup_playbooks.py output
#   IMPLEMENT_PLAYBOOK_ID — from scripts/setup_playbooks.py output
#   ACU_LIMIT_TRIAGE      — default: 8
#   ACU_LIMIT_IMPLEMENT   — default: 50

# === Optional (defaults shown, for local use / Settings class) ===
# TARGET_REPO=finserv-demo/finserv
# MAX_CONCURRENT_IMPLEMENT=10
# MAX_CONCURRENT_TOTAL=20
# ACU_LIMIT_TRIAGE=8
# ACU_LIMIT_IMPLEMENT=50
# OPT_OUT_LABEL=devin:skip

# Playbook IDs (set after running scripts/setup_playbooks.py)
# TRIAGE_PLAYBOOK_ID=
# IMPLEMENT_PLAYBOOK_ID=
