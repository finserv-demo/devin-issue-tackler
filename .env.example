# === Required ===
# GitHub webhook secret (for HMAC signature verification)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Devin API key (cog_* service user credential or apk_* personal key)
DEVIN_API_KEY=cog_your_key_here

# Devin organization ID
DEVIN_ORG_ID=org-your-org-id-here

# GitHub token (PAT or App token with repo scope)
GITHUB_TOKEN=ghp_your_token_here

# === Optional (defaults shown) ===
# TARGET_REPO=finserv-demo/finserv
# MAX_CONCURRENT_IMPLEMENT=10
# MAX_CONCURRENT_TOTAL=20
# POLLING_INTERVAL_SECONDS=15
# BULK_TRIAGE_RATE_LIMIT=5
# ACU_LIMIT_TRIAGE=8
# ACU_LIMIT_IMPLEMENT=50
# OPT_OUT_LABEL=devin:skip

# Playbook IDs (set after running scripts/setup_playbooks.py)
# TRIAGE_PLAYBOOK_ID=
# IMPLEMENT_PLAYBOOK_ID=
